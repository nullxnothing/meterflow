# ═══════════════════════════════════════════════════
# Meterflow Agent — Environment Config
# ═══════════════════════════════════════════════════

# ─── OpenClaw ─────────────────────────────────────
OPENCLAW_GATEWAY_TOKEN=          # Auth token for gateway UI
OPENCLAW_STATE_DIR=/data/.openclaw
OPENCLAW_WORKSPACE_DIR=/data/workspace

# ─── Skyfire ──────────────────────────────────────
SKYFIRE_API_KEY=                 # Buyer agent API key from app.skyfire.xyz

# ─── Solana ───────────────────────────────────────
SOLANA_PRIVATE_KEY=              # Base58 encoded private key for the agent's wallet
HELIUS_API_KEY=                  # Helius RPC API key

# ─── LLM ─────────────────────────────────────────
ANTHROPIC_API_KEY=               # For Claude API access (backup / initial bootstrap)

# ─── Treasury Agent ──────────────────────────────
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
TREASURY_WALLET=                 # Public key of the 50% API treasury wallet
PROXY_ADMIN_URL=http://localhost:3001
PROXY_ADMIN_KEY=
COST_PER_CALL_USD=0.02
SOL_PRICE_USD=150
AGENT_PORT=3002
DISCORD_WEBHOOK_URL=             # Discord webhook for #treasury-updates channel

# ─── Safety Limits ───────────────────────────────
MAX_SOL_PER_SWAP=5               # Max SOL per Jupiter swap transaction
MAX_DAILY_SKYFIRE_DEPOSIT=50     # Max USDC deposited to Skyfire per day
MIN_WALLET_RESERVE=0.1           # Never swap below this SOL balance
SOL_SWAP_THRESHOLD=0.5           # Trigger swap when balance exceeds this
DEPLOY_COOLDOWN_MINUTES=30       # Min minutes between token deploys

# ─── Privacy.com (Virtual Cards) ─────────────────
PRIVACY_API_KEY=                 # From privacy.com/account#api-key
PRIVACY_SANDBOX=false            # Set true for sandbox.privacy.com

# ─── Bridge.xyz (USDC → Fiat Off-Ramp) ──────────
BRIDGE_API_KEY=                  # From dashboard.bridge.xyz
BRIDGE_SANDBOX=false             # Set true for api.sandbox.bridge.xyz
BRIDGE_CUSTOMER_ID=              # Created via POST /customers (after KYC)
BRIDGE_EXTERNAL_ACCOUNT_ID=      # Bank account ID from POST /external_accounts
BRIDGE_LIQUIDATION_ADDRESS=      # Solana address from POST /liquidation_addresses
BRIDGE_LIQ_ADDR_ID=             # Liquidation address ID for drain monitoring
MAX_DAILY_OFFRAMP_USD=200        # Max USD to off-ramp per day
MIN_OFFRAMP_AMOUNT=10            # Min USDC to trigger off-ramp

# ─── x402 Protocol ───────────────────────────────
X402_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402
CDP_API_KEY=                     # Coinbase CDP API key (optional, for default facilitator)
X402_MAX_PER_REQUEST_USD=0.10    # Max USDC per single x402 request
X402_MAX_DAILY_USD=10.00         # Max USDC via x402 per day
