{
  "rewrites": [
    { "source": "/proxy/:path*", "destination": "/api/proxy" },
    { "source": "/api/:path*", "destination": "/api/proxy" },
    { "source": "/health", "destination": "/api/proxy" },
    { "source": "/skill.md", "destination": "/skills/meterflow-api/SKILL.md" },
    { "source": "/how-it-works", "destination": "/site/how-it-works.html" },
    { "source": "/docs", "destination": "/site/docs.html" },
    { "source": "/docs.html", "destination": "/site/docs.html" },
    { "source": "/roadmap", "destination": "/site/roadmap.html" },
    { "source": "/apply", "destination": "/site/apply.html" },
    { "source": "/apply/:path*", "destination": "/site/apply.html" },
    { "source": "/admin/applications", "destination": "/site/admin-applications.html" },
    { "source": "/admin/applications/:path*", "destination": "/site/admin-applications.html" },
    { "source": "/dashboard", "destination": "/dashboard/index.html" },
    { "source": "/privacy", "destination": "/site/privacy.html" },
    { "source": "/terms", "destination": "/site/terms.html" },
    { "source": "/404", "destination": "/site/404.html" },
    { "source": "/", "destination": "/site/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "geolocation=(), microphone=(), camera=()" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
