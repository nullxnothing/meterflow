# ═══════════════════════════════════════════
# Meterflow — API Proxy Configuration
# ═══════════════════════════════════════════

# Server
PORT=3001
NODE_ENV=development

# AI Provider Keys (YOUR master keys — never exposed to users)
ANTHROPIC_API_KEY=sk-ant-xxxxx
GOOGLE_API_KEY=AIzaxxxxx
OPENAI_API_KEY=sk-proj-xxxxx

# Solana / Helius
HELIUS_API_KEY=your-helius-key
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your-helius-key
# Canonical $MFLOW contract address. Set this once and the site/API use it everywhere.
METERFLOW_TOKEN_CA=
# Backward-compatible alias; leave empty if METERFLOW_TOKEN_CA is set.
METERFLOW_TOKEN_MINT=
METERFLOW_TOKEN_NAME=Meterflow
METERFLOW_TOKEN_SYMBOL=MFLOW
METERFLOW_TOKEN_SWAP_URL=
METERFLOW_PROTOCOL_FEE_BPS=100
METERFLOW_HOLDER_PROTOCOL_FEE_BPS=0
SETTLEMENT_WALLET=your-settlement-wallet-public-key

# Machine Payments Protocol (optional rail beside x402)
# Set METERFLOW_DEFAULT_PAYMENT_PROTOCOL=mpp only when you want first 402
# challenges to prefer MPP over x402 for callers that do not opt in by header.
MPP_SECRET_KEY=change-this-to-a-random-256-bit-secret
MPP_PAY_TO=your-settlement-wallet-public-key
MPP_SOLANA_NETWORK=mainnet-beta
MPP_SOLANA_RPC_URL=
MPP_REALM=meterflow.fun
MPP_VERIFY_TIMEOUT_MS=60000
METERFLOW_DEFAULT_PAYMENT_PROTOCOL=x402
METERFLOW_PUBLIC_URL=https://www.meterflow.fun

# Zauth x402 monitoring (optional, provider telemetry/refund layer)
# Middleware is mounted before x402 when ZAUTH_API_KEY is set.
ZAUTH_API_KEY=
ZAUTH_BASE_URL=https://api.zauth.inc
ZAUTH_PUBLIC_APP_URL=https://zauth.inc
ZAUTH_INCLUDE_ROUTES=^/mcp/.*,^/gateway/.*
ZAUTH_EXCLUDE_ROUTES=^/health$,^/auth/.*,^/oauth/.*,^/discord/.*,^/holder/.*
ZAUTH_INCLUDE_REQUEST_BODY=false
ZAUTH_INCLUDE_RESPONSE_BODY=true
ZAUTH_BATCH_SIZE=10
ZAUTH_BATCH_WAIT_MS=100
ZAUTH_REFUNDS_ENABLED=false
# Required only if refunds are enabled for Solana payments.
ZAUTH_SOLANA_PRIVATE_KEY=
ZAUTH_MAX_REFUND_USD=1.00

# Postgres (persistent control plane: meters, receipts, budgets, MCP tools, webhooks)
DATABASE_URL=postgres://user:password@localhost:5432/meterflow
POSTGRES_SSL=false
POSTGRES_POOL_MAX=5

# Redis (rate limiting, API keys, usage counters, and session cache)
REDIS_URL=redis://localhost:6379

# Token tier thresholds (raw token amounts, adjust for decimals)
TIER_SIGNAL_MIN=10000
TIER_OPERATOR_MIN=100000
TIER_ARCHITECT_MIN=1000000

# Rate limits (calls per 24h)
TIER_SIGNAL_DAILY_LIMIT=1000
TIER_OPERATOR_DAILY_LIMIT=10000
TIER_ARCHITECT_DAILY_LIMIT=999999

# Proxy secret for signing API keys (REQUIRED in production — no dev defaults)
API_KEY_SECRET=change-this-to-a-random-256-bit-hex-string

# Admin key for treasury agent push (REQUIRED in production)
ADMIN_KEY=change-this-to-a-random-secret

# Wallet allowlist for admin/test access (comma-separated)
WHITELISTED_WALLETS=

# Trading Bot
WALLET_ENCRYPTION_SECRET=change-this-to-a-random-64-char-hex-string
HELIUS_WS_URL=wss://mainnet.helius-rpc.com/?api-key=your-helius-key
JUPITER_API_KEY=

# OAuth Integrations (for user-connected accounts)
OAUTH_REDIRECT_BASE=http://localhost:3001
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# Ops alert webhook (optional)
ERROR_ALERT_WEBHOOK=

# Error tracking (optional)
SENTRY_DSN=
