{
  "name": "meterflow",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.6.2",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "analyze": "vite build --mode analyze",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck && npm run lint:styles",
    "lint:styles": "node scripts/style-guard.mjs",
    "audit:css": "node scripts/css-token-audit.mjs",
    "test": "npm run test -w api-proxy",
    "smoke:prod": "node scripts/smoke-production.mjs",
    "smoke:paid": "node scripts/smoke-paid-x402.mjs",
    "smoke:zauth": "node scripts/smoke-zauth.mjs",
    "migrate": "npm run migrate -w api-proxy",
    "api": "npm run start -w api-proxy"
  },
  "overrides": {
    "rpc-websockets": "9.3.3"
  },
  "dependencies": {
    "@fontsource/geist": "^5.2.8",
    "@fontsource/geist-mono": "^5.2.7",
    "@fontsource/instrument-serif": "^5.2.8",
    "@gsap/react": "^2.1.2",
    "@payai/facilitator": "^2.4.1",
    "@sentry/node": "^10.39.0",
    "@solana/kit": "^5.5.1",
    "@solana/web3.js": "^1.98.4",
    "@upstash/redis": "^1.36.2",
    "@x402/core": "^2.11.0",
    "@x402/express": "^2.11.0",
    "@x402/svm": "^2.11.0",
    "@zauthx402/sdk": "^0.1.14",
    "bn.js": "^5.2.2",
    "bs58": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "gsap": "^3.15.0",
    "ioredis": "^5.3.2",
    "lucide-react": "^1.16.0",
    "mppx": "^0.6.20",
    "node-cron": "^3.0.3",
    "pg": "^8.16.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "socket.io": "^4.8.3",
    "solana-mpp": "^0.1.1",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0",
    "tweetnacl": "^1.0.3",
    "wouter": "^3.9.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^4.7.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "serve": "^14.2.6",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  },
  "workspaces": [
    "api-proxy"
  ]
}
